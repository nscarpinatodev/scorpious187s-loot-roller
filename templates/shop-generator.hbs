{{!-- Shop Generator — bulk inventory generator for a merchant or treasure room --}}
<div class="shop-generator-content">

  {{#unless hasAdapter}}
    <p class="no-adapter">{{localize "LOOTROLLER.warn.noAdapterDescription"}}</p>
  {{else}}

  {{!-- Shop configuration --}}
  <div class="shop-config">

    <div class="form-group">
      <label>{{localize "LOOTROLLER.shop.shopName"}}</label>
      <input type="text" name="shopName" value="{{shopName}}"
        placeholder="{{localize 'LOOTROLLER.shop.shopNamePlaceholder'}}" />
    </div>

    <div class="form-group">
      <label>{{localize "LOOTROLLER.shop.itemCount"}}</label>
      <input type="number" name="itemCount" value="{{itemCount}}" min="1" max="50" />
    </div>

    {{!-- Adapter-provided filter fields (rarity buttons, party level, etc.) --}}
    {{#each filterFields}}
      <div class="filter-group">
        <label class="filter-label">{{localize this.label}}</label>
        {{#if (lootrollerEq this.type "rarity-buttons")}}
          <div class="filter-buttons">
            {{#each this.options}}
              <button type="button" data-action="toggle-rarity" data-rarity="{{this.value}}"
                class="filter-btn rarity-btn {{lootrollerRarityClass this.value}}{{#if this.selected}} selected{{/if}}">
                {{localize this.label}}
              </button>
            {{/each}}
          </div>
        {{/if}}
        {{#if (lootrollerEq this.type "number")}}
          <div class="party-level-input">
            <input type="number" class="filter-number-field" data-filter-key="{{this.key}}"
              value="{{this.current}}" min="{{this.min}}" max="{{this.max}}" />
          </div>
        {{/if}}
        {{#if (lootrollerEq this.type "select")}}
          <select class="filter-select-field" data-filter-key="{{this.key}}">
            {{#each this.options}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>
        {{/if}}
        {{#if (lootrollerEq this.type "level-range")}}
          <div class="level-range-slider" data-filter-key="{{this.key}}"
            data-min="{{this.min}}" data-max="{{this.max}}">
            <div class="level-range-readout">
              <span class="level-range-label">{{localize "LOOTROLLER.levelRange.low"}}
                <strong class="level-range-value-low">{{this.low}}</strong></span>
              <span class="level-range-label">{{localize "LOOTROLLER.levelRange.high"}}
                <strong class="level-range-value-high">{{this.high}}</strong></span>
            </div>
            <div class="level-range-track">
              <div class="level-range-fill"></div>
              <input type="range" class="level-range-low" data-filter-key="{{this.key}}"
                min="{{this.min}}" max="{{this.max}}" step="1" value="{{this.low}}" />
              <input type="range" class="level-range-high" data-filter-key="{{this.key}}"
                min="{{this.min}}" max="{{this.max}}" step="1" value="{{this.high}}" />
            </div>
          </div>
        {{/if}}
      </div>
    {{/each}}

    {{!-- Item type filters (adapter-provided) --}}
    {{#if itemTypes.length}}
    <div class="filter-group">
      <label class="filter-label">{{localize "LOOTROLLER.shop.itemTypes"}} <span class="hint-inline">{{localize "LOOTROLLER.quest.itemTypesHint"}}</span></label>
      <div class="filter-buttons">
        {{#each itemTypes}}
          <button type="button" data-action="toggle-type" data-item-type="{{this.value}}"
            class="filter-btn type-btn {{#if (lootrollerIncludes ../selectedTypes this.value)}}selected{{/if}}">
            {{localize this.label}}
          </button>
        {{/each}}
      </div>
    </div>
    {{/if}}

    <button type="button" class="btn-generate" data-action="generate">
      {{#if generating}}
        <i class="fa-solid fa-spinner fa-spin"></i>
        {{localize "LOOTROLLER.shop.generating"}}
      {{else if hasItems}}
        <i class="fa-solid fa-rotate"></i>
        {{localize "LOOTROLLER.shop.addMore"}}
      {{else}}
        <i class="fa-solid fa-store"></i>
        {{localize "LOOTROLLER.shop.generate"}}
      {{/if}}
    </button>

  </div>

  {{!-- Generated inventory --}}
  {{#if hasItems}}
    <div class="shop-inventory">
      <div class="loot-results-header">
        <h3 class="section-label">
          <i class="fa-solid fa-boxes-stacked"></i>
          {{localize "LOOTROLLER.shop.inventory"}}
          <span class="item-count">({{items.length}})</span>
        </h3>
        <button type="button" class="btn-icon-remove" data-action="clear-inventory"
                title="{{localize 'LOOTROLLER.shop.clearInventory'}}">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each items}}
          <div class="lottery-item {{#if this.stub}}stub{{/if}}">
            {{#if this.stub}}
              <img class="item-img" src="{{this.img}}" alt="{{this.name}}" />
            {{else}}
              <button type="button" class="item-img-btn" data-action="view-item" data-idx="{{this.idx}}"
                title="{{localize 'LOOTROLLER.lottery.viewItem'}}">
                <img class="item-img" src="{{this.img}}" alt="{{this.name}}" />
              </button>
            {{/if}}
            <div class="item-info">
              <span class="item-name">{{this.name}}</span>
              {{#if this.level}}
                <span class="item-level">{{localize "LOOTROLLER.levelRange.levelLabel"}} {{this.level}}</span>
              {{else if this.rarity}}
                <span class="item-rarity {{lootrollerRarityClass this.rarity}}">{{this.rarity}}</span>
              {{/if}}
            </div>
            <button type="button" class="btn-icon-remove" data-action="remove-item" data-idx="{{this.idx}}"
              title="{{localize 'LOOTROLLER.quest.removeItem'}}">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        {{/each}}
      </div>
      <div class="reward-actions">
        <button type="button" class="btn-distribute" data-action="create-shop">
          <i class="fa-solid fa-store"></i>
          {{localize "LOOTROLLER.shop.createShop"}}
        </button>
        {{#if canRestock}}
          <button type="button" class="btn-distribute btn-restock" data-action="restock-shop">
            <i class="fa-solid fa-boxes-packing"></i>
            {{localize "LOOTROLLER.shop.restock"}}
          </button>
        {{/if}}
      </div>
    </div>
  {{/if}}

  {{/unless}}
</div>
